# Copia in signing.env (non committare: è in .gitignore nella root del monorepo).
# release_wearos_apk.sh fa "source" automatico di signing.env se esiste qui.
#
# Genera il keystore una tantum (dedica una password e conservala):
#   cd extra/local-artifacts/wearos-kor35
#   keytool -genkeypair -v -keystore wear-release.jks -alias wear \
#     -keyalg RSA -keysize 2048 -validity 10000
#
# Percorso del file .jks: assoluto oppure relativo a questa cartella (wearos-kor35).
export WEAR_RELEASE_STORE_FILE=wear-release.jks
export WEAR_RELEASE_STORE_PASSWORD=cambia_questa_password
export WEAR_RELEASE_KEY_ALIAS=wear
# Opzionale se la password della chiave coincide con quella del keystore:
# export WEAR_RELEASE_KEY_PASSWORD=
