ENVIRONMENT=development
DEBUG=True

# Django/Backend
SECRET_KEY=dev-only-change-me
ALLOWED_HOSTS=127.0.0.1,localhost
REDIS_HOST=127.0.0.1

# Database locale (docker-compose.dev.yml)
DB_NAME=kor35_dev
DB_USER=kor35_dev
DB_PASSWORD=kor35_dev
DB_HOST=127.0.0.1
DB_PORT=5432

# Edge sync pull-only (Master -> locale)
# Endpoint del server master, es: https://www.kor35.it/api/sync/edge/
EDGE_SYNC_URL=
# Deve combaciare col token configurato sul Master
EDGE_SYNC_TOKEN=
# Nome nodo locale (solo etichetta)
EDGE_NODE_NAME=wsl-dev
# Stato ultimo pull applicato
EDGE_SYNC_STATE_FILE=/home/django/progetti/kor35/.edge_sync_state.json

# Email (placeholder per evitare errori di bootstrap settings.py)
SMTP_EMAIL=dev@example.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# OAuth Google (placeholder)
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# Origini locali opzionali
EXTRA_CSRF_TRUSTED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
EXTRA_CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173

# Sync media pull-only via rsync (script: scripts/sync_media_pull_wsl_pi_like.sh)
WSL_PI_REMOTE_SSH_USER=pi
WSL_PI_REMOTE_SSH_HOST=
WSL_PI_REMOTE_SSH_PORT=22
WSL_PI_REMOTE_MEDIA_DIR=/home/pi/kor35-replica/media_data/
