{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://kor35.it/schemas/carte-effect-script-v1.json",
  "title": "KOR35 Carte — EffectScript v1",
  "description": "Script effetti duello carte. Interpretato server-side; parametri [X] dalla keyword.",
  "type": "object",
  "required": ["version", "trigger", "steps"],
  "additionalProperties": false,
  "properties": {
    "version": {
      "type": "integer",
      "const": 1
    },
    "params": {
      "type": "object",
      "additionalProperties": {
        "$ref": "#/$defs/paramDef"
      }
    },
    "trigger": {
      "$ref": "#/$defs/trigger"
    },
    "steps": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "#/$defs/step"
      }
    }
  },
  "$defs": {
    "paramDef": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": {
          "enum": ["int", "string"]
        },
        "from_placeholder": {
          "type": "string",
          "pattern": "^[A-Z]+$"
        },
        "default": {
          "oneOf": [
            { "type": "integer" },
            { "type": "string" }
          ]
        }
      }
    },
    "trigger": {
      "type": "object",
      "required": ["event"],
      "additionalProperties": false,
      "properties": {
        "event": {
          "enum": [
            "on_play",
            "on_exhaust",
            "on_attack",
            "on_turn_start",
            "on_turn_end",
            "manual"
          ]
        },
        "source": {
          "enum": ["this", "self", "opponent"],
          "default": "this"
        }
      }
    },
    "valueRef": {
      "oneOf": [
        { "type": "integer" },
        { "type": "string", "minLength": 1 },
        {
          "type": "object",
          "required": ["ref"],
          "additionalProperties": false,
          "properties": {
            "ref": {
              "type": "string",
              "pattern": "^(param\\.[A-Z]+|choice\\.[a-z][a-z0-9_]*|context\\.[a-z][a-z0-9_]*)$"
            }
          }
        }
      ]
    },
    "choiceRef": {
      "type": "object",
      "required": ["ref"],
      "additionalProperties": false,
      "properties": {
        "ref": {
          "type": "string",
          "pattern": "^(param\\.[A-Z]+|choice\\.[a-z][a-z0-9_]*|context\\.[a-z][a-z0-9_]*)$"
        }
      }
    },
    "cardFilter": {
      "type": "object",
      "additionalProperties": false,
      "properties": {
        "target": {
          "enum": ["card", "hero"],
          "default": "card"
        },
        "zone": {
          "enum": ["hand", "field", "deck", "discard"]
        },
        "owner": {
          "enum": ["controller", "opponent", "self", "any"]
        },
        "occupied": {
          "type": "boolean",
          "default": true
        },
        "card_type": {
          "enum": ["PG", "OGG", "LUO", "EVT"]
        },
        "cost_play_lte": { "$ref": "#/$defs/valueRef" },
        "cost_play_gte": { "$ref": "#/$defs/valueRef" },
        "energy": { "type": "string", "minLength": 2, "maxLength": 3 }
      }
    },
    "stepPlayerChoice": {
      "type": "object",
      "required": ["type", "id", "filter"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "player_choice" },
        "id": {
          "type": "string",
          "pattern": "^[a-z][a-z0-9_]*$"
        },
        "prompt": { "type": "string", "maxLength": 500 },
        "optional": { "type": "boolean", "default": false },
        "min": { "type": "integer", "minimum": 0, "maximum": 15, "default": 0 },
        "max": { "type": "integer", "minimum": 1, "maximum": 15, "default": 1 },
        "filter": { "$ref": "#/$defs/cardFilter" }
      }
    },
    "stepReplace": {
      "type": "object",
      "required": ["type", "slot", "with"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "replace" },
        "slot": {
          "enum": ["this", "hero_0", "hero_1", "location"]
        },
        "with": { "$ref": "#/$defs/valueRef" },
        "skip_if_no_choice": { "type": "boolean", "default": false }
      }
    },
    "stepModifyEnergy": {
      "type": "object",
      "required": ["type", "target", "delta"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "modify_energy" },
        "target": { "enum": ["self", "opponent"] },
        "delta": { "$ref": "#/$defs/valueRef" }
      }
    },
    "stepModifyInfluence": {
      "type": "object",
      "required": ["type", "target", "delta"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "modify_influence" },
        "target": { "enum": ["self", "opponent"] },
        "delta": { "$ref": "#/$defs/valueRef" }
      }
    },
    "stepDealDamage": {
      "type": "object",
      "required": ["type", "amount"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "deal_damage" },
        "target": {
          "oneOf": [
            {
              "enum": [
                "opponent_influence",
                "hero_0",
                "hero_1",
                "opponent_hero_0",
                "opponent_hero_1"
              ]
            },
            { "$ref": "#/$defs/choiceRef" }
          ],
          "default": "opponent_influence"
        },
        "amount": { "$ref": "#/$defs/valueRef" }
      }
    },
    "stepDrawCards": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "draw_cards" },
        "count": { "$ref": "#/$defs/valueRef" },
        "target": { "enum": ["self", "opponent"], "default": "self" }
      }
    },
    "stepMoveCard": {
      "type": "object",
      "required": ["type", "from", "to"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "move_card" },
        "card": { "$ref": "#/$defs/valueRef" },
        "from": { "enum": ["hand", "deck", "discard", "field"] },
        "to": { "enum": ["hand", "deck", "discard", "field", "exhaust"] },
        "field_slot": {
          "enum": ["hero_0", "hero_1", "location", "object_0", "object_1"]
        }
      }
    },
    "stepModifyShell": {
      "type": "object",
      "required": ["type", "delta"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "modify_shell" },
        "hero": { "enum": ["this", "hero_0", "hero_1"], "default": "this" },
        "delta": { "$ref": "#/$defs/valueRef" },
        "set": { "type": "boolean", "default": false },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "stepHealHeroes": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "heal_heroes" },
        "target": {
          "enum": ["self_hero", "own_heroes", "own_non_exhausted"],
          "default": "self_hero"
        },
        "amount": {
          "oneOf": [
            { "type": "string", "const": "full" },
            { "type": "integer" },
            {
              "type": "object",
              "required": ["ref"],
              "additionalProperties": false,
              "properties": {
                "ref": {
                  "type": "string",
                  "pattern": "^(param\\.[A-Z]+|choice\\.[a-z][a-z0-9_]*|context\\.[a-z][a-z0-9_]*)$"
                }
              }
            }
          ],
          "default": 1
        }
      }
    },
    "stepSinergiaIfActive": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "sinergia_if_active" },
        "min_count": { "type": "integer", "minimum": 2, "maximum": 2, "default": 2 },
        "draw_count": { "$ref": "#/$defs/valueRef" },
        "draw_target": { "enum": ["self", "opponent"], "default": "self" },
        "energy_delta": { "$ref": "#/$defs/valueRef" },
        "energy_target": { "enum": ["self", "opponent"], "default": "self" }
      }
    },
    "stepModifyTaggedHeroes": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "modify_tagged_heroes" },
        "tag": { "type": "string", "minLength": 1 },
        "tags_any": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tags_all": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "owner": { "enum": ["controller", "opponent", "any"], "default": "controller" },
        "forza_delta": { "$ref": "#/$defs/valueRef" },
        "robustezza_delta": { "$ref": "#/$defs/valueRef" },
        "iniziativa_delta": { "$ref": "#/$defs/valueRef" }
      }
    },
    "stepDestroyHeroes": {
      "type": "object",
      "required": ["type"],
      "additionalProperties": false,
      "properties": {
        "type": { "const": "destroy_heroes" },
        "tag": { "type": "string", "minLength": 1 },
        "tags_any": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tags_all": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "tags_none": { "type": "array", "items": { "type": "string", "minLength": 1 } },
        "owner": { "enum": ["controller", "opponent", "any"], "default": "controller" },
        "optional": { "type": "boolean", "default": false }
      }
    },
    "step": {
      "oneOf": [
        { "$ref": "#/$defs/stepPlayerChoice" },
        { "$ref": "#/$defs/stepReplace" },
        { "$ref": "#/$defs/stepModifyEnergy" },
        { "$ref": "#/$defs/stepModifyInfluence" },
        { "$ref": "#/$defs/stepDealDamage" },
        { "$ref": "#/$defs/stepDrawCards" },
        { "$ref": "#/$defs/stepMoveCard" },
        { "$ref": "#/$defs/stepModifyShell" },
        { "$ref": "#/$defs/stepHealHeroes" },
        { "$ref": "#/$defs/stepSinergiaIfActive" },
        { "$ref": "#/$defs/stepModifyTaggedHeroes" },
        { "$ref": "#/$defs/stepDestroyHeroes" }
      ]
    }
  }
}
