# Copia in /etc/kor35/kiosk.env sul Pi kiosk (chmod 644).

# Server canonico (HTTPS in prod; in bosco il mirror risolve www.kor35.it in locale).
PILOT_BASE_URL=https://www.kor35.it

# Fallback opzionale solo se esplicito (es. lab a casa). Lasciare vuoto in produzione/bosco.
# PILOT_FALLBACK_BASE_URL=https://192.168.1.200

# 1 = chiedi URL all'avvio (zenity o TTY)
KOR35_KIOSK_PROMPT_URL=0

# Layout hardware (affiancati: grande a sinistra, touch a destra)
KIOSK_LAYOUT=side_by_side
# auto = assegna grande→status, piccolo→control via xrandr
# Per hardware KOR35 noto meglio output fissi (touch bar = HDMI-1):
KIOSK_DETECT_OUTPUTS=fixed
KIOSK_STATUS_OUTPUT=HDMI-2
KIOSK_CONTROL_OUTPUT=HDMI-1
KIOSK_STATUS_MODE=1920x1200
KIOSK_CONTROL_MODE=1920x440
# Touch fisico sulla barra control (1920x440) — obbligatorio se il touch resta sul grande
KIOSK_TOUCH_OUTPUT=HDMI-1
# Se il nome ILITEK non viene trovato: xinput list | grep -i touch → id numerico
# KIOSK_TOUCH_XINPUT_ID=6
KIOSK_TOUCH_DEVICE=ILITEK ILITEK-TOUCH

# Profili Chromium (separati → le finestre non si scambiano)
# KIOSK_STATUS_PROFILE=/home/pi/.config/kiosk-status
# KIOSK_CONTROL_PROFILE=/home/pi/.config/kiosk-control

# Disabilita kiosk senza disinstallare: sudo touch /etc/kor35/NO_KIOSK
