# Opzionale. Lasciare vuoto / non impostare = percorsi relativi (/api, /media) sullo stesso host del frontend.
# Solo se API e static sono su host diversi senza reverse proxy:
# VITE_API_URL=https://altro-host.example

# Notifiche push (service worker). Abilitate di default; imposta false per disattivare.
# VITE_WEBPUSH_ENABLED=false
