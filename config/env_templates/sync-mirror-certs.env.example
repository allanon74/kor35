# Copia locale (non committare):
#   cp config/env_templates/sync-mirror-certs.env.example .env.sync-mirror-certs
#
# Postazione dev (relay prod → mirror):
#   make sync-certs-prod-to-mirror
#
# Sul server prod (cert già locali su www.kor35.it):
#   make sync-certs-to-mirror ENV=prod

# --- Produzione (sorgente) — host www.kor35.it ---
PROD_SSH_USER=deploy
PROD_SSH_HOST=www.kor35.it
PROD_SSH_PORT=22
PROD_SSH_IDENTITY=~/.ssh/id_docker
PROD_REPO_PATH=/srv/kor35

# --- Mirror Pi (destinazione) — host kor35.ddns.net ---
MIRROR_SSH_USER=pi
MIRROR_SSH_HOST=kor35.ddns.net
MIRROR_SSH_PORT=10022
MIRROR_SSH_IDENTITY=~/.ssh/id_docker
MIRROR_REPO_PATH=/home/pi/kor35-replica
MIRROR_COMPOSE_PROJECT_NAME=kor35-replica

# Override avanzato (quasi mai necessario): alias da ~/.ssh/config con proxy, ecc.
# PROD_SSH_TARGET=kor35-prod
# MIRROR_SSH_TARGET=kor35-mirror
