# Template mirror Raspberry → copia in backend/.env.mirror
#
# Con ENVIRONMENT=raspberry_docker (compose) Django aggiunge anche "*" a ALLOWED_HOSTS per la LAN.
# Imposta comunque host pubblici noti (es. DDNS) per sicurezza e coerenza log.

DEBUG=False

SECRET_KEY=CHANGE_ME_GENERA_CHIAVE_LUNGA

# Host espliciti (oltre a "*" aggiunto automaticamente in modalità raspberry_docker).
ALLOWED_HOSTS=kor35.ddns.net,localhost,127.0.0.1

DB_NAME=kor35
DB_USER=kor35
DB_PASSWORD=CHANGE_ME

EDGE_SYNC_URL=
EDGE_SYNC_TOKEN=
EDGE_NODE_NAME=mirror-pi
EDGE_SYNC_VERBOSE_ERRORS=True

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

SMTP_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

# Pi / mirror: HTTP e HTTPS sul DDNS (browser e redirect misti).
EXTRA_CSRF_TRUSTED_ORIGINS=https://kor35.ddns.net,http://kor35.ddns.net
EXTRA_CORS_ALLOWED_ORIGINS=https://kor35.ddns.net,http://kor35.ddns.net
