# Template produzione → copia in backend/.env.prod
#
# Docker Compose (compose.base.yml) imposta nel container: DB_HOST, DB_PORT, REDIS_HOST,
# ENVIRONMENT, EDGE_SYNC_STATE_FILE.

DEBUG=False

# Obbligatorio in produzione: genera una chiave lunga e univoca (non committare il file reale).
SECRET_KEY=CHANGE_ME_GENERA_CHIAVE_LUNGA

# Host HTTP(S) ammessi (virgola, senza spazi). Includi dominio pubblico, app, eventuali IP.
ALLOWED_HOSTS=www.k-o-r-35.it,127.0.0.1,www.kor35.it,kor35.it,app.kor35.it,app.k-o-r-35.it,localhost,kor35.ddns.net,192.168.1.200,192.168.1.50

# DB: stessi valori di POSTGRES_DB / POSTGRES_USER / POSTGRES_PASSWORD in compose.base.yml
# (default compose: kor35_dev / kor35_dev / kor35_dev).
DB_NAME=kor35_dev
DB_USER=kor35_dev
DB_PASSWORD=kor35_dev

EDGE_SYNC_URL=
EDGE_SYNC_TOKEN=
EDGE_NODE_NAME=prod
EDGE_SYNC_VERBOSE_ERRORS=False

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

SMTP_EMAIL=
EMAIL_HOST=
EMAIL_PORT=587
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

EXTRA_CSRF_TRUSTED_ORIGINS=https://www.kor35.it,https://kor35.it,https://app.kor35.it
EXTRA_CORS_ALLOWED_ORIGINS=https://www.kor35.it,https://kor35.it,https://app.kor35.it

# Arcana SSO v2 (OAuth2 + PKCE)
ARCANA_SSO_ENABLED=False
ARCANA_SSO_BASE_URL=https://DOMINIO-AD/wp-json/ad-sso/v2
ARCANA_SSO_CLIENT_ID=
ARCANA_SSO_CLIENT_SECRET=
ARCANA_SSO_REDIRECT_URI=https://www.kor35.it/api/auth/arcana/callback/
ARCANA_SSO_FRONTEND_LOGIN_PATH=/login
