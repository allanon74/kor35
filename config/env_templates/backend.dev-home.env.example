# Template dev-home (Docker WSL) → copia in backend/.env.dev-home
#
# Con ENVIRONMENT=raspberry_docker (compose) viene aggiunto "*" a ALLOWED_HOSTS.

DEBUG=True

SECRET_KEY=CHANGE_ME_DEV_HOME_SECRET_KEY

ALLOWED_HOSTS=127.0.0.1,localhost

DB_NAME=kor35_dev
DB_USER=kor35_dev
DB_PASSWORD=kor35_dev

EDGE_SYNC_URL=
EDGE_SYNC_TOKEN=
EDGE_NODE_NAME=dev-home
EDGE_SYNC_VERBOSE_ERRORS=True

GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

SMTP_EMAIL=dev@example.local
EMAIL_HOST=localhost
EMAIL_PORT=1025
EMAIL_HOST_USER=
EMAIL_HOST_PASSWORD=

EXTRA_CSRF_TRUSTED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080
EXTRA_CORS_ALLOWED_ORIGINS=http://127.0.0.1:8080,http://localhost:8080

# Arcana SSO v2 (OAuth2 + PKCE)
ARCANA_SSO_ENABLED=False
ARCANA_SSO_BASE_URL=https://DOMINIO-AD/wp-json/ad-sso/v2
ARCANA_SSO_CLIENT_ID=
ARCANA_SSO_CLIENT_SECRET=
ARCANA_SSO_REDIRECT_URI=http://localhost:8080/api/auth/arcana/callback/
ARCANA_SSO_FRONTEND_LOGIN_PATH=/login
