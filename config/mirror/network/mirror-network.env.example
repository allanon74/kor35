# Config rete mirror Pi — copia in /etc/kor35/mirror-network.env (install_mirror_network.sh)
#
# Modalità:
#   router — Pi collegato al router di casa: NO DHCP locale 192.168.100.0/24
#   event  — bosco/offline: LAN evento + DHCP + DNS locale verso www.kor35.it
#   auto   — sceglie in base alla raggiungibilità internet (healthz master)

KOR35_REPO_PATH=/home/pi/kor35-replica
COMPOSE_PROJECT_NAME=kor35-replica

# LAN cablata verso switch/PoE Omada (rete evento)
EVENT_LAN_INTERFACE=eth0
EVENT_LAN_IP=192.168.100.1
EVENT_LAN_CIDR=24
EVENT_DHCP_RANGE_START=192.168.100.50
EVENT_DHCP_RANGE_END=192.168.100.200

# WiFi emergenza on-board (sempre attiva)
EMERGENCY_WIFI_INTERFACE=wlan0
EMERGENCY_WIFI_SSID=Pi_emergenza
EMERGENCY_WIFI_IP=10.42.0.1
EMERGENCY_WIFI_CIDR=24
# Imposta una PSK forte prima di install_mirror_network.sh
EMERGENCY_WIFI_PASSPHRASE=CHANGE_ME_EMERGENCY_PSK

# DNS locale in modalità evento (risolve i domini verso EVENT_LAN_IP)
LOCAL_DNS_DOMAINS=www.kor35.it,kor35.it,kor35.ddns.net

# Probe per modalità auto (master online = router, altrimenti event)
INTERNET_CHECK_URL=https://www.kor35.it/api/healthz/
INTERNET_CHECK_TIMEOUT_SEC=8
